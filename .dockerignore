# Keep the build context lean - the image only needs mcp/, agent/, addon/,
# the entrypoint, and .devcontainer/{blender.env,build-blender.sh}.
.git
**/__pycache__/
**/*.pyc
.mypy_cache/
.ruff_cache/
**/.ruff_cache/
**/*.egg-info/
**/build/
.test_venv/
.vscode/

# Components not shipped in the runtime image.
ext/
chat_client/
tests/
_misc/
rigging/

# mcp_ext ships (the rig/media_io tools ARE the agent's value-add), but
# its dev fixtures stay out of the context.
mcp_ext/blmcp_ext/rigging/tests/
mcp_ext/blmcp_ext/rigging/corpus/
mcp_ext/blmcp_ext/rigging/evals/
mcp_ext/blmcp_ext/rigging/logs/
mcp_ext/blmcp_ext/media/tests/

# Devcontainer: keep only the two files the Dockerfile copies.
.devcontainer/*
!.devcontainer/blender.env
!.devcontainer/build-blender.sh
