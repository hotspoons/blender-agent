{
  "manifest_version": "0.4",
  "name": "Blender",
  "version": "1.0.0",
  "description": "Interact with a running Blender instance – inspecting scenes, executing Python code, rendering, and navigating the interface.",
  "author": {
    "name": "Blender Lab",
    "url": "https://www.blender.org/lab/"
  },
  "homepage": "https://www.blender.org/lab/mcp-server/",
  "support": "https://projects.blender.org/lab/blender_mcp/issues/",
  "icon": "blender_icon_16x16.png",
  "server": {
    "type": "uv",
    "entry_point": "mcp/blcmp/__init__.py",
    "mcp_config": {
      "command": "uv",
      "args": [
        "run",
        "blender-mcp"
      ]
    }
  },
  "license": "GPL-3.0-or-later",
  "privacy_policies": [
    "https://www.blender.org/privacy-policy/"
  ],
  "compatibility": {
    "runtimes": {
      "python": ">= 3.10"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://projects.blender.org/lab/blender_mcp"
  }
}