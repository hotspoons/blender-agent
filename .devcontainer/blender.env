# Target Blender version for in-container testing.
#
# Single source of truth consumed by build-blender.sh (and anything
# else that needs the pinned version). Bump both lines together.
BLENDER_VERSION=5.1.2
BLENDER_GIT_TAG=v5.1.2
# Release directory on download.blender.org for the official-binary
# fast path (x86_64 only).
BLENDER_RELEASE_DIR=Blender5.1
