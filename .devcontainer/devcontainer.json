{
	"name": "blender-agent",
	"image": "mcr.microsoft.com/devcontainers/python:3.12",
	"features": {
		"ghcr.io/devcontainers/features/git:1": {},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "22"
		}
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"containerEnv": {
		"XDG_RUNTIME_DIR": "/tmp/xdg-runtime"
	},
	// Share the host's network namespace so tools in the container can
	// reach Blender + the agent running on the HOST (e.g. localhost:9876
	// bridge). On Docker Desktop (macOS/Windows) this requires "Enable
	// host networking" in Settings > Resources > Network; if you'd rather
	// not toggle that, drop runArgs and connect via host.docker.internal
	// instead (set BLENDER_MCP_HOST=host.docker.internal).
	"runArgs": ["--network=host"],
    "initializeCommand": "cmd.exe /c powershell -NoProfile -Command \"$ErrorActionPreference='SilentlyContinue'; New-Item -ItemType Directory -Force -Path $env:USERPROFILE\\.kube, $env:USERPROFILE\\.claude | Out-Null; if (!(Test-Path $env:USERPROFILE\\.claude.json)) { Set-Content -Path $env:USERPROFILE\\.claude.json -Value '{}' }\" || sh -c 'mkdir -p \"$HOME/.kube\" \"$HOME/.claude\" && touch \"$HOME/.claude.json\"'",
    
	"mounts": [
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/home/vscode/.claude.json,type=bind",
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"charliermarsh.ruff",
				"ms-python.mypy-type-checker",
				"anthropic.claude-code"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python",
				"python.analysis.extraPaths": [
					"mcp",
					"agent",
					"addon"
				],
				"[python]": {
					"editor.defaultFormatter": "charliermarsh.ruff"
				}
			}
		}
	}
}
